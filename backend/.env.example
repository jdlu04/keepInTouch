# Copy to `.env` and fill in. NEVER commit the real .env (it's gitignored).

# --- Database -------------------------------------------------------------
# PostgreSQL connection string. We host on Supabase but use it only as a DB.
# Get it from: Supabase Dashboard -> Project Settings -> Database ->
# "Connection string" -> URI. Use the "Session pooler" URI for an always-on
# server. Then:
#   • prefix the driver:  postgresql+psycopg2://
#   • append SSL:         ?sslmode=require
#
# Example (Supabase session pooler):
#   postgresql+psycopg2://postgres.abcxyz:YOUR-PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
#
# Local Postgres example:
#   postgresql+psycopg2://postgres:postgres@localhost:5432/kit
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/kit

# --- Auth -----------------------------------------------------------------
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080          # 7 days

# --- CORS -----------------------------------------------------------------
# Comma-separated list of allowed origins for the Expo app, or * for all (dev).
# Expo web dev server is usually http://localhost:8081.
CORS_ORIGINS=*
